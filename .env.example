# ============================================
# JobDog Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# JWT Authentication (REQUIRED)
# --------------------------------------------
# Generate a secure 32+ character secret:
# openssl rand -base64 32
APP_JWT_SECRET=CHANGE_ME_TO_A_SECURE_32_CHAR_SECRET
APP_JWT_EXPIRATION=PT12H

# --------------------------------------------
# OAuth2 Configuration (OPTIONAL)
# --------------------------------------------
# Google OAuth2 (get from https://console.cloud.google.com)
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=your-google-client-id
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2 (get from https://github.com/settings/developers)
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GITHUB_CLIENT_ID=your-github-client-id
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GITHUB_CLIENT_SECRET=your-github-client-secret

# --------------------------------------------
# Cloudflare R2 Storage (REQUIRED for resume uploads)
# --------------------------------------------
# Get from Cloudflare R2 dashboard
APP_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
APP_R2_BUCKET=resumes
APP_R2_ACCESS_KEY=your-r2-access-key
APP_R2_SECRET_KEY=your-r2-secret-key
APP_R2_REGION=auto

# --------------------------------------------
# OpenAI API (REQUIRED for resume parsing)
# --------------------------------------------
# Get from https://platform.openai.com/api-keys
APP_OPENAI_API_KEY=sk-your-openai-api-key

# --------------------------------------------
# Scraper Configuration (OPTIONAL)
# --------------------------------------------
# Override default Workday scraper sources
# Leave empty to use defaults (Meta, Stripe, Shopify, etc.)
WORKDAY_COMPANY=
WORKDAY_URL=

# --------------------------------------------
# Frontend Configuration
# --------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
