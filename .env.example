# ============================================
# JobDog Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# JWT Authentication (REQUIRED)
# --------------------------------------------
APP_JWT_SECRET=CHANGE_ME_TO_A_SECURE_32_CHAR_SECRET
APP_JWT_EXPIRATION=P7D

# --------------------------------------------
# OAuth2 Configuration (REQUIRED for Google/GitHub login)
# --------------------------------------------
# Google OAuth2 (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2 (get from https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# CRITICAL: Set these to your public domain — NOT the raw server IP.
# APP_OAUTH_REDIRECT_BASE = the base URL the OAuth provider redirects to (your backend proxy URL)
# APP_FRONTEND_BASE_URL   = where the browser lands after OAuth (your Vercel frontend URL)
APP_OAUTH_REDIRECT_BASE=https://jobdog.dev
APP_FRONTEND_BASE_URL=https://jobdog.dev

# --------------------------------------------
# Cloudflare R2 Storage (REQUIRED for resume uploads)
# --------------------------------------------
APP_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
APP_R2_BUCKET=resumes
APP_R2_ACCESS_KEY=your-r2-access-key
APP_R2_SECRET_KEY=your-r2-secret-key
APP_R2_REGION=auto

# --------------------------------------------
# OpenAI API (REQUIRED for resume parsing)
# --------------------------------------------
APP_OPENAI_API_KEY=sk-your-openai-api-key

# --------------------------------------------
# Scraper Configuration (OPTIONAL)
# --------------------------------------------
WORKDAY_COMPANY=
WORKDAY_URL=

# --------------------------------------------
# Frontend (Vercel env vars — set in Vercel dashboard, not here)
# --------------------------------------------
# NEXT_PUBLIC_API_URL is only needed for local dev
NEXT_PUBLIC_API_URL=http://localhost:8080
